---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
---

<DocsLayout title="高级用法" description="访问底层 MapLibre GL 实例进行高级自定义，包括 ref、useMap hook、自定义控件和图层。">
  <h1>高级用法</h1>
  <p class="text-lg text-[var(--color-text-secondary)] mb-8">
    访问底层 MapLibre GL 地图实例，使用 MapLibre GL JS API 的任何功能。
  </p>

  <p>
    你可以使用 <code class="text-[var(--color-brand-300)] bg-[var(--color-brand-500)]/10 px-1.5 py-0.5 rounded text-sm">ref</code> 或
    <code class="text-[var(--color-brand-300)] bg-[var(--color-brand-500)]/10 px-1.5 py-0.5 rounded text-sm">useMap</code> hook 访问底层 MapLibre GL 地图实例。
  </p>

  <div class="p-4 rounded-xl bg-[var(--color-brand-500)]/5 border border-[var(--color-brand-500)]/20 mb-8">
    <p class="text-sm text-[var(--color-brand-300)]">
      💡 <strong>提示：</strong>查看
      <a href="https://maplibre.org/maplibre-gl-js/docs/API/classes/Map/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-brand-400)] underline">MapLibre GL JS 文档</a>
      获取完整的方法和事件列表。
    </p>
  </div>

  <h2 id="using-ref">使用 Ref</h2>
  <p>访问地图实例最简单的方式。使用 <code class="text-[var(--color-brand-300)] bg-[var(--color-brand-500)]/10 px-1.5 py-0.5 rounded text-sm">ref</code> 从事件处理器或 effect 中调用地图方法：</p>
  <CodeBlock code={`import { Map, type MapRef } from "@/components/ui/map";
import { useRef } from "react";

function MyMapComponent() {
  const mapRef = useRef<MapRef>(null);

  const handleFlyTo = () => {
    // 通过 ref 访问 MapLibre GL 地图实例
    mapRef.current?.flyTo({ center: [-74, 40.7], zoom: 12 });
  };

  return (
    <>
      <button onClick={handleFlyTo}>飞往纽约</button>
      <Map ref={mapRef} center={[-74, 40.7]} zoom={10} />
    </>
  );
}`} lang="tsx" title="MyMapComponent.tsx" />

  <h2 id="using-hook">使用 Hook</h2>
  <p>对于在 <code class="text-[var(--color-brand-300)] bg-[var(--color-brand-500)]/10 px-1.5 py-0.5 rounded text-sm">Map</code> 内渲染的子组件，使用 <code class="text-[var(--color-brand-300)] bg-[var(--color-brand-500)]/10 px-1.5 py-0.5 rounded text-sm">useMap</code> hook 访问地图实例并监听事件：</p>
  <CodeBlock code={`import { Map, useMap } from "@/components/ui/map";
import { useEffect } from "react";

// 对于 Map 内的子组件，使用 useMap hook
function MapEventListener() {
  const { map, isLoaded } = useMap();

  useEffect(() => {
    if (!map || !isLoaded) return;

    const handleClick = (e) => {
      console.log("点击位置：", e.lngLat);
    };

    map.on("click", handleClick);
    return () => map.off("click", handleClick);
  }, [map, isLoaded]);

  return null;
}

// 用法
<Map center={[-74, 40.7]} zoom={10}>
  <MapEventListener />
</Map>`} lang="tsx" title="MapEventListener.tsx" />

  <h2 id="custom-controls">自定义控件</h2>
  <p>创建自定义控件来操作地图的倾斜和方向，并监听地图事件显示实时值：</p>
  <CodeBlock code={`"use client";

import { useEffect, useState } from "react";
import { Map, useMap } from "@/components/ui/map";
import { Button } from "@/components/ui/button";
import { RotateCcw, Mountain } from "lucide-react";

function MapController() {
  const { map, isLoaded } = useMap();
  const [pitch, setPitch] = useState(0);
  const [bearing, setBearing] = useState(0);

  useEffect(() => {
    if (!map || !isLoaded) return;

    const handleMove = () => {
      setPitch(Math.round(map.getPitch()));
      setBearing(Math.round(map.getBearing()));
    };

    map.on("move", handleMove);
    return () => {
      map.off("move", handleMove);
    };
  }, [map, isLoaded]);

  const handle3DView = () => {
    map?.easeTo({
      pitch: 60,
      bearing: -20,
      duration: 1000,
    });
  };

  const handleReset = () => {
    map?.easeTo({
      pitch: 0,
      bearing: 0,
      duration: 1000,
    });
  };

  if (!isLoaded) return null;

  return (
    <div className="absolute top-3 left-3 z-10 flex flex-col gap-2">
      <div className="flex gap-2">
        <Button size="sm" variant="secondary" onClick={handle3DView}>
          <Mountain className="mr-1.5 size-4" />
          3D 视图
        </Button>
        <Button size="sm" variant="secondary" onClick={handleReset}>
          <RotateCcw className="mr-1.5 size-4" />
          重置
        </Button>
      </div>
      <div className="bg-background/90 rounded-md border px-3 py-2 font-mono text-xs backdrop-blur">
        <div>倾斜：{pitch}°</div>
        <div>方向：{bearing}°</div>
      </div>
    </div>
  );
}

export function AdvancedUsageExample() {
  return (
    <div className="h-[420px] w-full">
      <Map center={[-73.9857, 40.7484]} zoom={15}>
        <MapController />
      </Map>
    </div>
  );
}`} lang="tsx" title="AdvancedUsageExample.tsx" />

  <h2 id="custom-geojson-layer">自定义 GeoJSON 图层</h2>
  <p>添加自定义 GeoJSON 数据为图层，支持填充和轮廓样式及悬停交互：</p>
  <CodeBlock code={`"use client";

import { useCallback, useEffect, useState } from "react";
import { Map, MapControls, useMap } from "@/components/ui/map";
import { Button } from "@/components/ui/button";
import { Layers, X } from "lucide-react";

const geojsonData = {
  type: "FeatureCollection" as const,
  features: [
    {
      type: "Feature" as const,
      properties: { name: "中央公园", type: "park" },
      geometry: {
        type: "Polygon" as const,
        coordinates: [[
          [-73.9731, 40.7644],
          [-73.9819, 40.7681],
          [-73.958, 40.8006],
          [-73.9493, 40.7969],
          [-73.9731, 40.7644],
        ]],
      },
    },
  ],
};

function CustomLayer() {
  const { map, isLoaded } = useMap();
  const [isLayerVisible, setIsLayerVisible] = useState(false);
  const [hoveredPark, setHoveredPark] = useState<string | null>(null);

  const addLayers = useCallback(() => {
    if (!map) return;
    if (!map.getSource("parks")) {
      map.addSource("parks", { type: "geojson", data: geojsonData });
    }
    if (!map.getLayer("parks-fill")) {
      map.addLayer({
        id: "parks-fill",
        type: "fill",
        source: "parks",
        paint: {
          "fill-color": "#22c55e",
          "fill-opacity": 0.4,
        },
        layout: {
          visibility: isLayerVisible ? "visible" : "none",
        },
      });
    }
  }, [map, isLayerVisible]);

  useEffect(() => {
    if (!map || !isLoaded) return;
    addLayers();

    const handleMouseMove = (e) => {
      const features = map.queryRenderedFeatures(e.point, {
        layers: ["parks-fill"],
      });
      if (features.length > 0) {
        setHoveredPark(features[0].properties?.name || null);
      }
    };

    map.on("mousemove", "parks-fill", handleMouseMove);
    return () => {
      map.off("mousemove", "parks-fill", handleMouseMove);
    };
  }, [map, isLoaded, isLayerVisible]);

  const toggleLayer = () => {
    if (!map) return;
    const visibility = isLayerVisible ? "none" : "visible";
    map.setLayoutProperty("parks-fill", "visibility", visibility);
    setIsLayerVisible(!isLayerVisible);
  };

  return (
    <>
      <div className="absolute top-3 left-3 z-10">
        <Button size="sm" variant={isLayerVisible ? "default" : "secondary"} onClick={toggleLayer}>
          {isLayerVisible ? <X className="mr-1.5 size-4" /> : <Layers className="mr-1.5 size-4" />}
          {isLayerVisible ? "隐藏公园" : "显示公园"}
        </Button>
      </div>
      {hoveredPark && (
        <div className="bg-background/90 absolute bottom-3 left-3 z-10 rounded-md border px-3 py-2 text-sm font-medium backdrop-blur">
          {hoveredPark}
        </div>
      )}
    </>
  );
}`}` lang="tsx" title="CustomLayer.tsx" />

  <h2 id="markers-via-layers">通过图层渲染标记（性能优化）</h2>
  <p>
    当需要显示数百或数千个标记时，使用 GeoJSON 图层代替基于 DOM 的
    <code class="text-[var(--color-brand-300)] bg-[var(--color-brand-500)]/10 px-1.5 py-0.5 rounded text-sm">MapMarker</code> 组件。
    这种方式在 WebGL 画布上渲染标记，性能显著提升。
  </p>
  <CodeBlock code={`"use client";

import { useEffect, useState, useId } from "react";
import { Map, MapPopup, useMap } from "@/components/ui/map";

function MarkersLayer() {
  const { map, isLoaded } = useMap();
  const id = useId();
  const sourceId = \`markers-source-\${id}\`;
  const layerId = \`markers-layer-\${id}\`;
  const [selectedPoint, setSelectedPoint] = useState(null);

  useEffect(() => {
    if (!map || !isLoaded) return;

    map.addSource(sourceId, {
      type: "geojson",
      data: pointsData, // 包含 200 个点的 FeatureCollection
    });

    map.addLayer({
      id: layerId,
      type: "circle",
      source: sourceId,
      paint: {
        "circle-radius": 6,
        "circle-color": "#3b82f6",
        "circle-stroke-width": 2,
        "circle-stroke-color": "#ffffff",
      },
    });

    const handleClick = (e) => {
      if (!e.features?.length) return;
      const feature = e.features[0];
      const coords = feature.geometry.coordinates;
      setSelectedPoint({
        id: feature.properties?.id,
        name: feature.properties?.name,
        coordinates: coords,
      });
    };

    map.on("click", layerId, handleClick);
    return () => {
      map.off("click", layerId, handleClick);
      if (map.getLayer(layerId)) map.removeLayer(layerId);
      if (map.getSource(sourceId)) map.removeSource(sourceId);
    };
  }, [map, isLoaded]);

  return (
    <>
      {selectedPoint && (
        <MapPopup
          longitude={selectedPoint.coordinates[0]}
          latitude={selectedPoint.coordinates[1]}
          onClose={() => setSelectedPoint(null)}
          closeButton
        >
          <div className="min-w-24">
            <p className="font-medium">{selectedPoint.name}</p>
          </div>
        </MapPopup>
      )}
    </>
  );
}`}` lang="tsx" title="MarkersLayer.tsx" />

  <div class="mt-12 p-6 rounded-xl bg-[var(--color-bg-surface)] border border-[var(--color-border-default)]">
    <p class="text-sm text-[var(--color-text-tertiary)] mb-2">了解更多</p>
    <div class="flex flex-wrap gap-3">
      <a href="https://maplibre.org/maplibre-gl-js/docs/API/classes/Map/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-brand-400)] hover:text-[var(--color-brand-300)] transition-colors">
