      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
        {providers.map((provider) => (
          <div class="p-5 rounded-xl bg-[var(--color-bg-surface)] border border-[var(--color-border-default)] card-hover text-center reveal">
