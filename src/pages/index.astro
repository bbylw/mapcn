  <!-- ============ CTA ============ -->
  <section class="relative py-24 lg:py-32">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-[var(--color-bg-surface)] border border-[var(--color-brand-500)]/15 p-12 lg:p-16 bg-noise">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[500px] bg-[var(--color-brand-500)]/12 rounded-full blur-[130px]"></div>
        <div class="absolute inset-0 bg-grid opacity-10"></div>

        <div class="relative text-center max-w-2xl mx-auto">
          <h2 class="font-display text-4xl lg:text-5xl font-bold tracking-tight mb-6">
            准备好开始了吗？
          </h2>
          <p class="text-lg text-[var(--color-text-secondary)] mb-10">
            一条命令安装，几分钟内将交互式地图集成到你的 React 应用中。
            完全拥有代码，零锁定。
