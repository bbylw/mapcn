  <!-- ============ PROVIDERS ============ -->
  <section class="relative py-24 lg:py-32 border-y border-[var(--color-border-subtle)] bg-[var(--color-bg-surface)]/30">
    <div class="absolute inset-0 bg-grid-sm opacity-15"></div>
