---
const navLinks = [
  { href: "/", label: "首页" },
  { href: "/docs", label: "文档" },
  { href: "/docs/installation", label: "安装" },
  { href: "/docs/api-reference", label: "API" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 glass-strong border-b border-[var(--color-border-subtle)]">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="relative w-8 h-8 flex items-center justify-center">
          <svg viewBox="0 0 32 32" class="w-8 h-8" fill="none">
            <rect x="2" y="2" width="28" height="28" rx="7" stroke="url(#nav-logo-grad)" stroke-width="1.5" />
            <path d="M16 8C12.5 8 10 10.5 10 14C10 18 16 24 16 24C16 24 22 18 22 14C22 10.5 19.5 8 16 8Z" fill="url(#nav-logo-grad)" fill-opacity="0.15" stroke="url(#nav-logo-grad)" stroke-width="1.5" />
            <circle cx="16" cy="14" r="2" fill="#22d3ee" />
            <defs>
              <linearGradient id="nav-logo-grad" x1="2" y1="2" x2="30" y2="30" gradientUnits="userSpaceOnUse">
                <stop stop-color="#22d3ee" />
                <stop offset="1" stop-color="#0891b2" />
              </linearGradient>
            </defs>
          </svg>
        </div>
        <span class="font-display text-lg font-bold tracking-tight">mapcn</span>
        <span class="hidden sm:inline-block text-[10px] px-1.5 py-0.5 rounded bg-[var(--color-brand-500)]/10 text-[var(--color-brand-400)] border border-[var(--color-brand-500)]/20 font-mono leading-none">CN</span>
      </a>

      <!-- Nav Links -->
      <div class="hidden md:flex items-center gap-0.5">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-3.5 py-2 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] rounded-lg transition-all duration-200"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/AnmolSaini16/mapcn"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-2 px-3 py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          <span class="font-mono text-xs">10.7k</span>
        </a>
        <a
          href="/docs"
          class="px-4 py-2 text-sm font-medium text-[var(--color-bg-base)] bg-[var(--color-brand-500)] hover:bg-[var(--color-brand-400)] rounded-lg transition-all duration-200 active:scale-[0.97]"
        >
          快速开始
        </a>
      </div>
    </div>
  </div>
</nav>
<div class="h-16"></div>
