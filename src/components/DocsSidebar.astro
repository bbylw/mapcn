---
const sidebarSections = [
  {
    title: "基础",
    items: [
      { href: "/docs", label: "快速开始" },
      { href: "/docs/installation", label: "安装指南" },
      { href: "/docs/api-reference", label: "API 参考" },
    ],
  },
  {
    title: "组件",
    items: [
      { href: "/docs/basic-map", label: "Map 地图" },
      { href: "/docs/controls", label: "Controls 控件" },
      { href: "/docs/markers", label: "Markers 标记" },
      { href: "/docs/popups", label: "Popups 弹窗" },
      { href: "/docs/routes", label: "Routes 路线" },
      { href: "/docs/arcs", label: "Arcs 弧线" },
      { href: "/docs/geojson", label: "GeoJSON" },
      { href: "/docs/clusters", label: "Clusters 聚类" },
      { href: "/docs/advanced-usage", label: "高级用法" },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<aside class="hidden lg:block w-60 flex-shrink-0 py-8">
  <div class="sticky top-24 space-y-8">
    {sidebarSections.map((section) => (
      <div>
        <h4 class="text-xs font-semibold text-[var(--color-text-tertiary)] uppercase tracking-wider mb-3 px-3">
          {section.title}
        </h4>
        <ul class="space-y-0.5">
          {section.items.map((item) => {
            const isActive = currentPath === item.href ||
              (item.href !== "/docs" && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "block px-3 py-1.5 text-sm rounded-lg transition-all duration-200",
                    isActive
                      ? "bg-[var(--color-brand-500)]/10 text-[var(--color-brand-400)] font-medium border-l-2 border-[var(--color-brand-500)]"
                      : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)]"
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
</aside>
